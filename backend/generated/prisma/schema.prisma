// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// This generates the Prisma client
generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["driverAdapters"]
}

// This defines PostgreSQL as the database provider
datasource db {
  provider = "postgresql"
}

// This represents a registered user of the application 
model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  password     String
  createdAt    DateTime      @default(now())
  applications Application[]
}

// This represents a single job application on the Kanban board
model Application {
  id        Int             @id @default(autoincrement())
  company   String
  role      String
  location  String?
  url       String?
  contact   String?
  stage     Stage           @default(APPLIED)
  priority  Boolean         @default(false)
  appliedAt DateTime        @default(now())
  deadline  DateTime?
  notes     String?
  userId    Int
  user      User            @relation(fields: [userId], references: [id])
  history   StatusHistory[]
}

// This logs each time an application moves between Kanban stages
model StatusHistory {
  id            Int         @id @default(autoincrement())
  stage         Stage
  changedAt     DateTime    @default(now())
  applicationId Int
  application   Application @relation(fields: [applicationId], references: [id])
}

// This defines the four Kanban stages an application can be in
enum Stage {
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
}
